# Скопируйте этот файл в .env и заполните значения:
#   cp .env.example .env
#
# .env читается docker-compose автоматически и НЕ коммитится в git.

# ── GitHub Packages (нужны для сборки образов — доступ к приватным зависимостям) ──
GITHUB_USER=your-github-username
GITHUB_TOKEN=your-github-token

# ── Telegram ──
TELEGRAM_BOT_TOKEN=your-bot-token
# Список Telegram user ID через запятую, которым разрешён доступ (пусто = все)
TELEGRAM_ALLOWED_USER_IDS=
# true — отключает проверку подписи initData (удобно для разработки)
TELEGRAM_DEV_MODE=true

# ── Frontend ──
# URL бэкенда, видимый из браузера (не из контейнера!)
API_BASE_URL=http://localhost:8080

# ── Хранилище медиафайлов на хосте ──
TGVD_MEDIA_DIR=~/Downloads/tgvd/media
TGVD_TEMP_DIR=~/Downloads/tgvd/temp

# ── yt-dlp (опционально) ──
# Путь к файлу cookies в формате Netscape
YTDLP_COOKIES_FILE=

